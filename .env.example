# mlbma-pipeline environment — copy to .env (gitignored) and fill in.
# These are the variables the pipeline / dashboard exporters actually read.

# ── Supabase (REQUIRED for the hub_dataset mirror — Step 20 / outputs/push_supabase.py) ──
# Without a write key the mirror SILENTLY SKIPS and hub_dataset goes stale while the rest
# of the pipeline keeps running. push_supabase.py accepts any of the names below; set one.
SUPABASE_URL=https://<ref>.supabase.co
SUPABASE_KEY=<service_role or sb_secret_… write key>
# Equivalent accepted aliases (use whichever your tooling already sets):
# SUPABASE_SECRET_KEY=
# SUPABASE_SERVICE_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# ── FanGraphs (REQUIRED for the FanGraphs Selenium scraper) ──
FANGRAPHS_EMAIL=
FANGRAPHS_PASSWORD=
# Path to a Chrome/Chromium binary for undetected-chromedriver (optional; auto-detected if unset)
CHROME_PATH=

# ── Optional ──
MLBMA_SLATE_DATE=          # override the slate date (YYYY-MM-DD); defaults to today
SHARP_MONEY_DIR=           # path to the sharp-money-tracker repo, if integrating
INSTAGRAM_PUBLISH=         # 1 to enable IG auto-post (outputs/push_instagram.py)
INSTAGRAM_AUTO_POST=
INSTAGRAM_GRAPH_VERSION=
INSTAGRAM_IMAGE_URL=
